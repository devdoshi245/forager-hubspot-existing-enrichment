# Backfill tool — required credentials (same values as the live service's Railway env).

# Forager API
FORAGER_API_KEY=your_forager_api_key_here
FORAGER_ACCOUNT_ID=your_forager_account_id_here

# HubSpot Private App token
HUBSPOT_TOKEN=your_hubspot_private_app_token_here

# --- Company scoring (ICP fit + logo) — needed for the COMPANIES backfill --------
# Without a key, company enrichment still writes firmographics but skips scoring/Tier.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-opus-4-8
# SCORING_PROVIDER=anthropic

# CONTACT_OWNER — owner for any records the core logic touches (optional here).
# CONTACT_OWNER=OneGTM Labs

# --- Deepline (Workflow 3 on contacts: work email + phone) ----------------------
# Set to activate the Deepline step after the Forager reveal. Per-provider BYOK keys
# + credits are configured in the Deepline dashboard, NOT here. If unset, contacts
# still get the Forager reveal and the Deepline step is skipped.
# DEEPLINE_API_KEY=dlp_xxx

# --- Optional knobs reused from the core service --------------------------------
# TIER_FIELD=tier
